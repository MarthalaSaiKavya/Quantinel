# IBM Quantum API credentials and configuration
# NOTE: I used my personal API token and instance for testing purposes. You should replace these values with your own credentials. — GT (10780)

$env:IBM_QUANTUM_TOKEN    = "[quantum_token]"
$env:IBM_QUANTUM_INSTANCE = "ibm-q/open/main"   # hub/group/project
$env:IBM_QUANTUM_CHANNEL  = "ibm_quantum"        # or "ibm_cloud"
$env:IBM_QUANTUM_BACKEND  = ""                   # leave blank → least-busy real device
